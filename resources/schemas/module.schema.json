{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Laravel Modular Configuration",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "description": "The name of the module."
        },
        "description": {
            "type": "string",
            "description": "A brief description of the module."
        },
        "version": {
            "type": "string",
            "description": "The semantic version of the module."
        },
        "authors": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": { "type": "string" },
                    "email": { "type": "string", "format": "email" },
                    "role": { "type": "string" }
                },
                "required": ["name"]
            },
            "description": "The authors of the module."
        },
        "namespace": {
            "type": "string",
            "description": "The PSR-4 namespace of the module."
        },
        "removable": {
            "type": "boolean",
            "description": "Whether the module can be removed via commands",
            "default": true
        },
        "disableable": {
            "type": "boolean",
            "description": "Whether the module can be disabled via commands",
            "default": true
        },
        "route_prefix": {
            "type": "string",
            "description": "The URL prefix to automatically mount all module routes under"
        },
        "policies": {
            "type": "object",
            "description": "Model to Policy mapping"
        },
        "provider": {
            "type": ["string", "null"],
            "description": "The primary Service Provider for the module."
        },
        "requires": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of modules this module depends on."
        },
        "events": {
            "type": "object",
            "patternProperties": {
                "^.*$": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "description": "Explicit map of Event classes to their array of Listener classes."
        },
        "extra": {
            "type": "object",
            "description": "Any additional custom configuration."
        }
    },
    "required": ["name"]
}
